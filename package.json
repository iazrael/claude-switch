{
  "name": "claude-switch",
  "version": "3.1.0",
  "type": "module",
  "description": "Claude Code 套餐管理工具 - CLI + Web 管理端，支持日志备份和一键还原",
  "main": "dist/index.js",
  "bin": {
    "claude-switch": "./dist/index.js"
  },
  "scripts": {
    "build": "pnpm build:backend && pnpm build:frontend",
    "build:backend": "tsup",
    "build:frontend": "cd frontend && pnpm build",
    "start": "node dist/server.js",
    "cli": "node dist/index.js",
    "test": "vitest run --pool=forks",
    "test:watch": "vitest --pool=forks",
    "dev": "concurrently \"tsx src/server.ts\" \"cd frontend && pnpm dev\"",
    "dev:backend": "tsx src/server.ts",
    "dev:frontend": "cd frontend && pnpm dev"
  },
  "dependencies": {
    "chalk": "^5.6.2",
    "commander": "^11.1.0",
    "cors": "^2.8.5",
    "express": "^4.21.0",
    "fs-extra": "^11.2.0",
    "inquirer": "^8.2.5",
    "proper-lockfile": "^4.1.2"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/fs-extra": "^11.0.4",
    "@types/inquirer": "^9.0.9",
    "@types/node": "^25.6.2",
    "@types/proper-lockfile": "^4.1.4",
    "@types/supertest": "^7.2.0",
    "concurrently": "^9.1.2",
    "supertest": "^7.2.2",
    "tsup": "^8.5.1",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.5"
  }
}
